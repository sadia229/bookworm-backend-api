# --- Supabase ---
# Project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=change-me
# Server-only secret. Never expose to a client / commit to git.
SUPABASE_SERVICE_ROLE_KEY=change-me

# --- Auth (this backend's own JWTs, independent of Supabase Auth) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Firebase Cloud Messaging (push notifications) ---
# Paste the full service-account JSON as a single line, OR leave unset in dev
# (push sends are then skipped with a warning; token/history endpoints still work).
FIREBASE_CREDENTIALS_JSON=

# --- RevenueCat (v1.1 premium/IAP) ---
# Shared secret set on the RevenueCat webhook's Authorization header; the secret
# REST API key (v1) used by POST /users/me/premium/sync; and the entitlement id
# that grants premium. Leave unset in dev (webhook returns 401; sync returns 502).
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
REVENUECAT_ENTITLEMENT_ID=premium

# --- Admin & scheduled jobs (notifications) ---
# ADMIN_API_KEY authorizes admin writes (POST /summaries). CRON_SECRET is sent by
# Vercel Cron as `Authorization: Bearer <secret>` to the /cron/* endpoints.
# Generate each with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=
CRON_SECRET=

# --- CORS ---
CORS_ORIGINS=*

# --- Misc ---
ENVIRONMENT=development
